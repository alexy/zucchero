{
  "$schema": "../firstpair/publishing/book.build.schema.json",
  "schemaVersion": 1,
  "bookRoot": "docs/book",
  "manuscript": "docs/book/build/manuscript.generated.md",
  "metadata": "docs/book/metadata.yaml",
  "css": "docs/book/book.css",
  "stem": "zucchero",
  "headboardImage": "docs/book/assets/zucchero-headboard.png",
  "version": {
    "source": "file",
    "file": "docs/book/VERSION"
  },
  "dist": "docs/book/dist",
  "buildDir": "docs/book/build/firstpair",
  "cleanDist": true,
  "edition": "full",
  "primaryFormat": "typst",
  "mobi": false,
  "pdf": {
    "coverImage": "docs/book/assets/zucchero-cover.png",
    "coverWidth": "6in",
    "coverHeight": "9.6in",
    "coverFit": "cover"
  },
  "epub": {
    "coverImage": "docs/book/assets/zucchero-cover.png",
    "includeRenderedCover": false
  },
  "pandoc": {
    "reader": "markdown+smart",
    "tocDepth": 2,
    "numberSections": false,
    "resourcePaths": ["docs/book/build", "docs/book", "${repoRoot}"]
  },
  "html": {
    "splitLevel": 1
  },
  "hooks": {
    "prepare": {
      "python": "tools/prepare_public_book.py",
      "project": "tools/book-python"
    }
  }
}
